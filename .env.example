# Postgres
POSTGRES_URL=jdbc:postgresql://localhost:5433/signalfoundry
POSTGRES_USER=
POSTGRES_PASSWORD=

# Redis (password required — set by redis-server --requirepass)
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# Spring auth — must be at least 32 bytes for HS256
JWT_SECRET=

# Third-party API keys
OPENAI_API_KEY=
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
